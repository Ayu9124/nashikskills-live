# ============================================================
# NashikSkills Live - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Port for the backend server
PORT=5000

# Frontend URL (for CORS) - change in production
FRONTEND_URL=http://localhost:3000

# Firebase Admin SDK - Service Account JSON (stringified)
# Go to Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Then paste the entire JSON content as a single line here
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Firebase Firestore Database ID (from firebase-applet-config.json)
FIREBASE_DATABASE_ID=ai-studio-f1a13297-f988-49fb-bdb7-fff14455268b
