# ============================================================
# NashikSkills Live - Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# Your Gemini API key (get it from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# The URL where your app is hosted (used for links/callbacks)
APP_URL=http://localhost:3000
